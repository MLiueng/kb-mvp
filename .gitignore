# ==========================================
#  知识库系统 MVP - .gitignore
# ==========================================

# ---------- 环境配置（含 API Key，严禁提交）----------
.env
.env.local
.env.*.local

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ---------- 虚拟环境 ----------
.venv/
venv/
env/
ENV/

# ---------- 运行时数据 ----------
data/

# ---------- 日志与临时文件 ----------
*.log
*.log.*
*.tmp
*.bak
*.swp
*~

# ---------- 测试与覆盖率 ----------
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml

# ---------- IDE / 编辑器 ----------
.idea/
.vscode/
*.code-workspace
.project
.pydevproject
.settings/

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- 类型检查 ----------
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
