# ============================================================
#  知识库 MVP 环境变量示例
#  复制本文件为 .env 并填入真实值后使用
# ============================================================

# ============ LLM 对话模型配置 ============
# 提供商: dashscope | deepseek | glm | ollama | openai_compatible
LLM_PROVIDER=dashscope
# 模型名称（按提供商选择，示例见下方各供应商说明）
LLM_MODEL=qwen-plus
# API Key（dashscope 可留空则回退用 DASHSCOPE_API_KEY；ollama 本地留空）
LLM_API_KEY=
# API Base URL（留空使用提供商默认；openai_compatible 必填）
LLM_API_BASE=

# ============ Embedding 向量化模型配置 ============
# 提供商: dashscope | ollama | openai_compatible | deepseek | glm
EMBEDDING_PROVIDER=dashscope
# 模型名称
EMBEDDING_MODEL=text-embedding-v2
# API Key（dashscope 可留空则回退用 DASHSCOPE_API_KEY；ollama 本地留空）
EMBEDDING_API_KEY=
# API Base URL（留空使用提供商默认；openai_compatible 必填）
EMBEDDING_API_BASE=

# ============ 向后兼容：DashScope 通用 Key ============
# 当 LLM_PROVIDER/EMBEDDING_PROVIDER=dashscope 且对应 *_API_KEY 为空时回退使用
DASHSCOPE_API_KEY=

# ============ 分块与检索配置 ============
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
SERVER_PORT=8000

# ============================================================
#  各供应商配置示例（按需取消注释并填入）
# ============================================================

# ---- 通义千问 DashScope ----
# LLM_PROVIDER=dashscope
# LLM_MODEL=qwen-plus
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v2
# DASHSCOPE_API_KEY=sk-xxxxxxxx

# ---- DeepSeek ----
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxxxxxxx
# EMBEDDING_PROVIDER=deepseek
# EMBEDDING_MODEL=（DeepSeek 暂无 embedding，建议用其他）

# ---- 智谱 GLM ----
# LLM_PROVIDER=glm
# LLM_MODEL=glm-4
# LLM_API_KEY=xxxxxxxx
# EMBEDDING_PROVIDER=glm
# EMBEDDING_MODEL=embedding-3
# EMBEDDING_API_KEY=xxxxxxxx

# ---- Ollama 本地部署（LLM 与 Embedding 均可本地）----
# 前置：安装 Ollama 并拉取模型，如：ollama pull qwen2.5:7b / ollama pull bge-m3
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=bge-m3
# （本地部署无需 API Key，默认端点 http://localhost:11434/v1）

# ---- 任意 OpenAI 兼容端点 ----
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=your-model
# LLM_API_KEY=sk-xxxxxxxx
# LLM_API_BASE=https://your-endpoint/v1
